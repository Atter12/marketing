{
  "version": 2,
  "redirects": [
    { "source": "/tareas", "destination": "/pendientes", "permanent": true },
    { "source": "/tareas/", "destination": "/pendientes", "permanent": true },
    { "source": "/tareas/tarea.html", "destination": "/pendientes", "permanent": true },
    { "source": "/acceso-tareas", "destination": "/acceso-pendientes", "permanent": true }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "installCommand": "npm install && cd holistic-app && npm install",
  "framework": null,
  "functions": {
    "api/facebook/download.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/performance-analyzer/analyze.js": {
      "maxDuration": 60
    },
    "api/cobranzaClaudeSuggest.js": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
