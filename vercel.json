{
  "version": 2,
  "functions": {
    "api/tiktok/download.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type"
      }
    },
    {
      "src": "/tiktok-downloader",
      "dest": "/tiktok-downloader.html"
    },
    {
      "src": "/tiktok-downloader.html",
      "dest": "/tiktok-downloader.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}

