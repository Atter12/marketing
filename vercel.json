      "dest": "/pre-landing-builder.html"
    },
    {
      "src": "/qr-generator",
      "dest": "/qr-generator.html"
    },
    {
      "src": "/qr-generator.html",
      "dest": "/qr-generator.html"
    },
    {
      "src": "/url-shortener",
      "dest": "/url-shortener.html"
    },
    {
      "src": "/url-shortener.html",
      "dest": "/url-shortener.html"
    },
    {
      "src": "/pixel-activator",
      "dest": "/pixel-activator.html"
    },
    {
      "src": "/pixel-activator.html",
      "dest": "/pixel-activator.html"
