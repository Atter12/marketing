{
  "version": 2,
  "buildCommand": "echo 'No build required'",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/facebook/download.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/tiktok-downloader",
      "dest": "/tiktok-downloader.html"
    },
    {
      "src": "/tiktok-downloader.html",
      "dest": "/tiktok-downloader.html"
    },
    {
      "src": "/facebook-ads-downloader",
      "dest": "/facebook-ads-downloader.html"
    },
    {
      "src": "/facebook-ads-downloader.html",
      "dest": "/facebook-ads-downloader.html"
    },
    {
      "src": "/pre-landing-builder",
      "dest": "/pre-landing-builder.html"
    },
    {
      "src": "/pre-landing-builder.html",
      "dest": "/pre-landing-builder.html"
    },
    {
      "src": "/qr-generator",
      "dest": "/qr-generator.html"
    },
    {
      "src": "/qr-generator.html",
      "dest": "/qr-generator.html"
    },
    {
      "src": "/url-shortener",
      "dest": "/url-shortener.html"
    },
    {
      "src": "/url-shortener.html",
      "dest": "/url-shortener.html"
    },
    {
      "src": "/pixel-activator",
      "dest": "/pixel-activator.html"
    },
    {
      "src": "/pixel-activator",
      "dest": "/pixel-activator.html"
    },
    {
      "src": "/pixel-activator.html",
      "dest": "/pixel-activator.html"
    },
    {
      "src": "/landing",
      "dest": "/landing.html"
    },
    {
      "src": "/landing.html",
      "dest": "/landing.html"
    },
    {
      "src": "^/([a-zA-Z0-9-_]+)$",
      "dest": "/api/url-shortener/redirect?alias=$1",
      "check": true
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}

